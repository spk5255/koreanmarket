# ─── Korean Market Analyzer — environment template ───
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real keys.

# DART OpenAPI key — free at https://opendart.fss.or.kr (인증키 신청)
DART_API_KEY=

# Anthropic API key — for news sentiment + weekly report narrative
ANTHROPIC_API_KEY=

# Database URL. SQLite for dev; swap to Postgres/Timescale for prod.
#   sqlite:///data/market.db          (relative to project root)
#   postgresql+psycopg://user:pass@host:5432/market
KMA_DB_URL=sqlite:///data/market.db

# Anthropic model used for sentiment + report synthesis
KMA_ANTHROPIC_MODEL=claude-opus-4-8

# Logging: DEBUG | INFO | WARNING | ERROR
KMA_LOG_LEVEL=INFO

# Timezone for the weekly scheduler (KST so reports land before Monday open)
KMA_TIMEZONE=Asia/Seoul
